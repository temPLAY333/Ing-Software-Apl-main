# ================================
# Gestor de Docker - Versiones Ligera y Completa
# ================================

param(
    [Parameter(Mandatory=$false)]
    [ValidateSet("elk-lite", "lite", "full", "stats", "stop", "clean", "help")]
    [string]$Mode = "help"
)

function Show-Help {
    Write-Host "`n=== GESTOR DE DOCKER - VERSIÓN COMPLETA ===" -ForegroundColor Cyan
    Write-Host "`nUso: .\docker-lite-manager.ps1 [modo]`n"

    Write-Host "╔════════════════════════════════════════════════════════════════╗" -ForegroundColor Yellow
    Write-Host "║  MODOS CON ELK (Para presentaciones/demos)                    ║" -ForegroundColor Yellow
    Write-Host "╚════════════════════════════════════════════════════════════════╝" -ForegroundColor Yellow

    Write-Host "`n  elk-lite   - 🎯 ELK OPTIMIZADO para laptop (RECOMENDADO)" -ForegroundColor Green
    Write-Host "               Todo local: App + PostgreSQL + ELK reducido"
    Write-Host "               Consumo: ~1.5-2GB RAM, ~150-200% CPU" -ForegroundColor DarkGray
    Write-Host "               ⚡ Elasticsearch: 256MB, Logstash: 128MB, Kibana: 512MB" -ForegroundColor DarkGray

    Write-Host "`n  elk-remote - 🌐 Cliente ELK remoto (laptop sin ELK)" -ForegroundColor Cyan
    Write-Host "               Se conecta al ELK del PC principal"
    Write-Host "               Consumo: ~600MB RAM, ~80% CPU (solo App + DB)" -ForegroundColor DarkGray
    Write-Host "               ⚠️  Requiere configurar IP del servidor" -ForegroundColor DarkGray

    Write-Host "`n  elk-server - 🖥️  Servidor ELK (para PC principal)" -ForegroundColor Magenta
    Write-Host "               Solo servicios ELK expuestos en red"
    Write-Host "               Consumo: ~2.5GB RAM, ~250% CPU" -ForegroundColor DarkGray
    Write-Host "               🌍 Accesible desde otros dispositivos" -ForegroundColor DarkGray

    Write-Host "`n  full       - 📦 Stack COMPLETO original" -ForegroundColor Magenta
    Write-Host "               App + PostgreSQL + ELK + Filebeat completos"
    Write-Host "               Consumo: ~3.5GB RAM, ~320% CPU" -ForegroundColor DarkGray

    Write-Host "`n╔════════════════════════════════════════════════════════════════╗" -ForegroundColor Yellow
    Write-Host "║  MODOS SIN ELK (Desarrollo diario)                            ║" -ForegroundColor Yellow
    Write-Host "╚════════════════════════════════════════════════════════════════╝" -ForegroundColor Yellow

    Write-Host "`n  lite       - Versión ligera (App + PostgreSQL)" -ForegroundColor Green
    Write-Host "               Consumo: ~600MB RAM, ~100% CPU" -ForegroundColor DarkGray

    Write-Host "`n  db-only    - Solo PostgreSQL (app local con Maven)" -ForegroundColor Blue
    Write-Host "               Consumo: ~150MB RAM, ~30% CPU" -ForegroundColor DarkGray
    Write-Host "               Luego ejecuta: .\mvnw spring-boot:run" -ForegroundColor DarkGray

    Write-Host "`n╔════════════════════════════════════════════════════════════════╗" -ForegroundColor Yellow
    Write-Host "║  UTILIDADES                                                    ║" -ForegroundColor Yellow
    Write-Host "╚════════════════════════════════════════════════════════════════╝" -ForegroundColor Yellow

    Write-Host "`n  stats      - Monitoreo de recursos en tiempo real" -ForegroundColor Cyan
    Write-Host "  stop       - Detener todos los contenedores" -ForegroundColor Red
    Write-Host "  clean      - Limpiar contenedores y volúmenes" -ForegroundColor DarkRed
    Write-Host "  help       - Muestra esta ayuda`n" -ForegroundColor White

    Write-Host "╔════════════════════════════════════════════════════════════════╗" -ForegroundColor Green
    Write-Host "║  ESCENARIOS DE USO RECOMENDADOS                               ║" -ForegroundColor Green
    Write-Host "╚════════════════════════════════════════════════════════════════╝" -ForegroundColor Green

    Write-Host "`n📚 PRESENTACIÓN EN LAPTOP:" -ForegroundColor Yellow
    Write-Host "   .\docker-lite-manager.ps1 elk-lite" -ForegroundColor White

    Write-Host "`n💻 DESARROLLO DIARIO (laptop):" -ForegroundColor Yellow
    Write-Host "   .\docker-lite-manager.ps1 lite" -ForegroundColor White

    Write-Host "`n🌐 PRESENTACIÓN CON 2 DISPOSITIVOS:" -ForegroundColor Yellow
    Write-Host "   PC Principal:  .\docker-lite-manager.ps1 elk-server" -ForegroundColor White
    Write-Host "   Laptop:        .\docker-lite-manager.ps1 elk-remote" -ForegroundColor White

    Write-Host "`n🖥️  DESARROLLO COMPLETO (PC principal):" -ForegroundColor Yellow
    Write-Host "   .\docker-lite-manager.ps1 full`n" -ForegroundColor White
}

function Start-ElkLite {
    Write-Host "`n[ELK-LITE] Iniciando ELK ULTRA OPTIMIZADO para laptop..." -ForegroundColor Green
    Write-Host "Consumo esperado: ~1-1.2GB RAM, ~120-150% CPU`n" -ForegroundColor Yellow
    Write-Host "⚠️  Nota: Más lento pero consume menos recursos`n" -ForegroundColor Yellow

    # Detener otras versiones
    docker-compose -f docker-compose-lite.yml down 2>$null
    docker-compose -f docker-compose-full.yml down 2>$null

    # Iniciar ELK Lite
    docker-compose -f docker-compose-elk-lite.yml up -d

    if ($LASTEXITCODE -eq 0) {
        Write-Host "`n✅ ELK LITE iniciado correctamente" -ForegroundColor Green
        Write-Host "`nServicios disponibles:" -ForegroundColor Cyan
        Write-Host "  - Aplicación: http://localhost:8080"
        Write-Host "  - PostgreSQL: localhost:5432"
        Write-Host "  - Elasticsearch: http://localhost:9200"
        Write-Host "  - Kibana: http://localhost:5601"
        Write-Host "  - Logstash: localhost:5000"
        Write-Host "  - MailDev: http://localhost:1080`n"

        Write-Host "💡 Tip: Espera 60-90 segundos para que Kibana inicie completamente`n" -ForegroundColor Yellow

        Start-Sleep -Seconds 2
        Show-Stats
    }
}

function Start-ElkRemote {
    Write-Host "`n[ELK-REMOTE] Iniciando cliente ELK remoto..." -ForegroundColor Cyan
    Write-Host "Consumo esperado: ~600MB RAM, ~80% CPU`n" -ForegroundColor Yellow

    Write-Host "⚠️  IMPORTANTE: Antes de continuar, configura la IP del servidor" -ForegroundColor Red
    Write-Host "Edita: docker-compose-elk-remote.yml" -ForegroundColor Yellow
    Write-Host "Busca 'extra_hosts' y reemplaza '192.168.1.100' por la IP de tu PC principal`n" -ForegroundColor Yellow

    $serverIp = Read-Host "Ingresa la IP del PC principal (o Enter para usar 192.168.1.100)"
    if ([string]::IsNullOrWhiteSpace($serverIp)) {
        $serverIp = "192.168.1.100"
    }

    Write-Host "`nUsando servidor ELK en: $serverIp" -ForegroundColor Green
    Write-Host "Asegúrate de que el servidor ELK esté corriendo en el PC principal`n" -ForegroundColor Yellow

    # Detener otras versiones
    docker-compose -f docker-compose-elk-lite.yml down 2>$null
    docker-compose -f docker-compose-elk-server.yml down 2>$null
    docker-compose -f docker-compose-lite.yml down 2>$null
    docker-compose -f docker-compose-full.yml down 2>$null

    # Iniciar cliente remoto
    docker-compose -f docker-compose-elk-remote.yml up -d

    if ($LASTEXITCODE -eq 0) {
        Write-Host "`n✅ Cliente ELK remoto iniciado" -ForegroundColor Green
        Write-Host "`nServicios locales:" -ForegroundColor Cyan
        Write-Host "  - Aplicación: http://localhost:8080"
        Write-Host "  - PostgreSQL: localhost:5432"
        Write-Host "`nServicios remotos (en $serverIp):" -ForegroundColor Cyan
        Write-Host "  - Elasticsearch: http://$serverIp`:9200"
        Write-Host "  - Kibana: http://$serverIp`:5601"
        Write-Host "  - Logstash: $serverIp`:5000`n"

        Start-Sleep -Seconds 2
        Show-Stats
    }
}

function Start-ElkServer {
    Write-Host "`n[ELK-SERVER] Iniciando servidor ELK..." -ForegroundColor Magenta
    Write-Host "Consumo esperado: ~2.5GB RAM, ~250% CPU`n" -ForegroundColor Yellow

    # Obtener IP local
    $localIp = (Get-NetIPAddress -AddressFamily IPv4 -InterfaceAlias "Ethernet*","Wi-Fi*" | Where-Object {$_.IPAddress -notlike "169.254.*"} | Select-Object -First 1).IPAddress

    Write-Host "🌍 Este servidor será accesible en la red" -ForegroundColor Yellow
    Write-Host "Tu IP local es: $localIp" -ForegroundColor Green
    Write-Host "`nConfigura esta IP en el cliente (laptop) en docker-compose-elk-remote.yml`n" -ForegroundColor Yellow

    # Detener otras versiones
    docker-compose -f docker-compose-elk-lite.yml down 2>$null
    docker-compose -f docker-compose-elk-remote.yml down 2>$null
    docker-compose -f docker-compose-lite.yml down 2>$null
    docker-compose -f docker-compose-full.yml down 2>$null

    # Iniciar servidor ELK
    docker-compose -f docker-compose-elk-server.yml up -d

    if ($LASTEXITCODE -eq 0) {
        Write-Host "`n✅ Servidor ELK iniciado correctamente" -ForegroundColor Green
        Write-Host "`nServicios disponibles (acceso local):" -ForegroundColor Cyan
        Write-Host "  - Elasticsearch: http://localhost:9200"
        Write-Host "  - Kibana: http://localhost:5601"
        Write-Host "  - Logstash: localhost:5000"

        Write-Host "`nServicios disponibles (acceso remoto):" -ForegroundColor Cyan
        Write-Host "  - Elasticsearch: http://$localIp`:9200"
        Write-Host "  - Kibana: http://$localIp`:5601"
        Write-Host "  - Logstash: $localIp`:5000`n"

        Write-Host "💡 Asegúrate de que el firewall permita conexiones en los puertos 9200, 5601, 5000`n" -ForegroundColor Yellow

        Start-Sleep -Seconds 2
        Show-Stats
    }
}

function Start-Lite {
    Write-Host "`n[LITE] Iniciando versión LIGERA (sin ELK)..." -ForegroundColor Green
    Write-Host "Consumo esperado: ~600MB RAM, ~100% CPU`n" -ForegroundColor Yellow

    # Detener otras versiones
    docker-compose -f docker-compose-elk-lite.yml down 2>$null
    docker-compose -f docker-compose-elk-remote.yml down 2>$null
    docker-compose -f docker-compose-elk-server.yml down 2>$null
    docker-compose -f docker-compose-full.yml down 2>$null

    # Iniciar versión lite
    docker-compose -f docker-compose-lite.yml up -d

    if ($LASTEXITCODE -eq 0) {
        Write-Host "`n✅ Versión LITE iniciada correctamente" -ForegroundColor Green
        Write-Host "`nServicios disponibles:" -ForegroundColor Cyan
        Write-Host "  - Aplicación: http://localhost:8080"
        Write-Host "  - PostgreSQL: localhost:5432"
        Write-Host "  - MailDev: http://localhost:1080`n"

        Start-Sleep -Seconds 2
        Show-Stats
    }
}

function Start-Full {
    Write-Host "`n[FULL] Iniciando versión COMPLETA con ELK..." -ForegroundColor Magenta
    Write-Host "Consumo esperado: ~3.5GB RAM, ~300-400% CPU`n" -ForegroundColor Yellow
    Write-Host "⚠️  ADVERTENCIA: Requiere al menos 4GB RAM disponibles`n" -ForegroundColor Red

    # Detener otras versiones
    docker-compose -f docker-compose-elk-lite.yml down 2>$null
    docker-compose -f docker-compose-elk-remote.yml down 2>$null
    docker-compose -f docker-compose-elk-server.yml down 2>$null
    docker-compose -f docker-compose-lite.yml down 2>$null

    # Iniciar versión full
    docker-compose -f docker-compose-full.yml up -d

    if ($LASTEXITCODE -eq 0) {
        Write-Host "`n✅ Versión FULL iniciada correctamente" -ForegroundColor Green
        Write-Host "`nServicios disponibles:" -ForegroundColor Cyan
        Write-Host "  - Aplicación: http://localhost:8080"
        Write-Host "  - PostgreSQL: localhost:5432"
        Write-Host "  - Elasticsearch: http://localhost:9200"
        Write-Host "  - Kibana: http://localhost:5601"
        Write-Host "  - Logstash: localhost:5000"
        Write-Host "  - MailDev: http://localhost:1080`n"

        Start-Sleep -Seconds 2
        Show-Stats
    }
}

function Show-Stats {
    Write-Host "`n=== ESTADÍSTICAS DE RECURSOS ===" -ForegroundColor Cyan
    Write-Host ""

    # Estadísticas en formato tabla
    docker stats --no-stream --format "table {{.Name}}\t{{.CPUPerc}}\t{{.MemUsage}}\t{{.MemPerc}}"

    Write-Host "`n💡 Tip: Para monitoreo continuo, usa: docker stats`n" -ForegroundColor Yellow
}

function Stop-All {
    Write-Host "`n[STOP] Deteniendo todos los contenedores..." -ForegroundColor Red

    docker-compose -f docker-compose-elk-lite.yml down 2>$null
    docker-compose -f docker-compose-elk-remote.yml down 2>$null
    docker-compose -f docker-compose-elk-server.yml down 2>$null
    docker-compose -f docker-compose-lite.yml down 2>$null
    docker-compose -f docker-compose-full.yml down 2>$null

    Write-Host "✅ Contenedores detenidos`n" -ForegroundColor Green
}

function Clean-All {
    Write-Host "`n[CLEAN] Limpiando contenedores, redes y volúmenes..." -ForegroundColor DarkRed
    Write-Host "⚠️  ADVERTENCIA: Esto eliminará todos los datos de la base de datos`n" -ForegroundColor Red

    $confirmation = Read-Host "¿Estás seguro? (S/N)"
    if ($confirmation -eq 'S' -or $confirmation -eq 's') {
        docker-compose -f docker-compose-elk-lite.yml down -v 2>$null
        docker-compose -f docker-compose-elk-remote.yml down -v 2>$null
        docker-compose -f docker-compose-elk-server.yml down -v 2>$null
        docker-compose -f docker-compose-lite.yml down -v 2>$null
        docker-compose -f docker-compose-full.yml down -v 2>$null

        # Limpiar recursos huérfanos
        docker system prune -f

        Write-Host "✅ Limpieza completada`n" -ForegroundColor Green
    } else {
        Write-Host "❌ Limpieza cancelada`n" -ForegroundColor Yellow
    }
}

# ================================
# MAIN
# ================================
switch ($Mode) {
    "elk-lite"   { Start-ElkLite }
    "elk-remote" { Start-ElkRemote }
    "elk-server" { Start-ElkServer }
    "lite"       { Start-Lite }
    "full"       { Start-Full }
    "stats"      { Show-Stats }
    "stop"       { Stop-All }
    "clean"      { Clean-All }
    "help"       { Show-Help }
    default      { Show-Help }
}
