# ================================
# Docker Ignore File
# Exclude unnecessary files from Docker build context
# ================================

# Node modules y cache
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# Build outputs (except JAR for simple build)
target/classes/
target/generated-sources/
target/generated-test-sources/
target/test-classes/
target/spotless-index
target/checksums.csv
target/angular/
target/antrun/
target/node/
dist/
build/
*.war

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.metadata/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# Documentation
docs/
*.md
!README.md

# Tests
src/test/
cypress/
*.spec.ts
*.test.ts

# Configuration that shouldn't be in image
.env
.env.*
*.local

# Logs
logs/
*.log

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
Jenkinsfile
.gitlab-ci.yml
.github/

# Misc
.mvn/wrapper/maven-wrapper.jar
