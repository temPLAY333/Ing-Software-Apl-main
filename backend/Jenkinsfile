pipeline {
    agent any

    // Tools configuration removed - using built-in tools from Jenkins container
    // tools {
    //     maven 'Maven 3.9'
    //     jdk 'JDK 17'
    //     nodejs 'Node 18'
    // }

    environment {
        APP_NAME = 'library'
        DOCKER_IMAGE = "library/app"
        // DOCKER_CREDENTIALS = credentials('docker-hub-credentials')  // Configure this for DockerHub push
        K8S_NAMESPACE = 'production'
    }

    stages {
        stage('Checkout') {
            steps {
                echo '📦 Checking out source code...'
                checkout scm
                sh 'git rev-parse --short HEAD > .git/commit-id'
                script {
                    env.GIT_COMMIT_SHORT = readFile('.git/commit-id').trim()
                }
            }
        }

        stage('Build') {
            steps {
                echo '🔨 Building application...'
                dir('backend') {
                    sh '''
                        chmod +x mvnw
                        ./mvnw clean install -DskipTests
                    '''
                }
            }
        }

        stage('Unit Tests') {
            parallel {
                stage('Backend Tests') {
                    steps {
                        echo '🧪 Running backend tests...'
                        dir('backend') {
                            sh './mvnw test'
                        }
                    }
                    post {
                        always {
                            junit 'backend/target/surefire-reports/**/*.xml'
                            // jacoco execPattern: 'backend/target/jacoco.exec',
                            //        classPattern: 'backend/target/classes',
                            //        sourcePattern: 'backend/src/main/java'
                        }
                    }
                }
                stage('Frontend Tests') {
                    when {
                        expression { false }  // DISABLED - Node.js may not be available
                    }
                    steps {
                        echo '🧪 Running frontend tests...'
                        dir('backend') {
                            sh '''
                                npm ci
                                npm run test:ci
                            '''
                        }
                    }
                }
            }
        }

        stage('Code Quality Analysis') {
            when {
                expression { false }  // DISABLED - SonarQube not required for basic deployment
            }
            steps {
                echo '📊 Running SonarQube analysis...'
                dir('backend') {
                    withSonarQubeEnv('SonarQube') {
                        sh './mvnw sonar:sonar -Dsonar.login=$SONAR_TOKEN'
                    }
                }
            }
        }

        stage('Quality Gate') {
            when {
                expression { false }  // DISABLED - SonarQube not required for basic deployment
            }
            steps {
                echo '🚦 Checking quality gate...'
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Security Scan') {
            when {
                expression { false }  // DISABLED - Takes too long for demo
            }
            steps {
                echo '🔒 Running security scan...'
                dir('backend') {
                    sh '''
                        # OWASP Dependency Check
                        ./mvnw org.owasp:dependency-check-maven:check
                    '''
                }
            }
            post {
                always {
                    publishHTML([
                        reportDir: 'backend/target/dependency-check-report',
                        reportFiles: 'dependency-check-report.html',
                        reportName: 'OWASP Dependency Check'
                    ])
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo '🐳 Building Docker image...'
                dir('backend') {
                    script {
                        env.IMAGE_TAG = "${env.GIT_COMMIT_SHORT}"
                        sh """
                            docker build -t ${DOCKER_IMAGE}:${IMAGE_TAG} .
                            docker tag ${DOCKER_IMAGE}:${IMAGE_TAG} ${DOCKER_IMAGE}:latest
                        """
                    }
                }
            }
        }

        stage('Push Docker Image') {
            when {
                expression { false }  // DISABLED - Requires DockerHub credentials configuration
            }
            steps {
                echo '📤 Pushing Docker image to registry...'
                echo '⚠️  Skipped - Configure docker-hub-credentials in Jenkins to enable'
                // Uncomment below when credentials are configured:
                // script {
                //     sh """
                //         echo \$DOCKER_CREDENTIALS_PSW | docker login -u \$DOCKER_CREDENTIALS_USR --password-stdin
                //         docker push ${DOCKER_IMAGE}:${IMAGE_TAG}
                //         docker push ${DOCKER_IMAGE}:latest
                //     """
                // }
            }
        }

        stage('E2E Tests') {
            when {
                expression { false }  // DISABLED - Requires running application
            }
            steps {
                echo '🎭 Running E2E tests...'
                echo '⚠️  Skipped - E2E tests require application to be running'
            }
        }

        stage('Deploy to K8s') {
            when {
                expression { false }  // DISABLED - Kubernetes not required
            }
            steps {
                echo '🚀 Deploying to Kubernetes...'
                echo '⚠️  Skipped - Kubernetes deployment not configured'
            }
        }
    }

    post {
        always {
            echo '🧹 Cleaning workspace...'
            cleanWs()
        }
        success {
            echo '✅ Pipeline completed successfully!'
            // Slack notification
            script {
                def message = """
                    *BUILD SUCCESS* ✅
                    Job: ${env.JOB_NAME}
                    Build: #${env.BUILD_NUMBER}
                    Commit: ${env.GIT_COMMIT_SHORT}
                    Duration: ${currentBuild.durationString}
                """.stripIndent()

                // slackSend(color: 'good', message: message, channel: '#builds')
            }
        }
        failure {
            echo '❌ Pipeline failed!'
            script {
                def message = """
                    *BUILD FAILED* ❌
                    Job: ${env.JOB_NAME}
                    Build: #${env.BUILD_NUMBER}
                    Commit: ${env.GIT_COMMIT_SHORT}
                    Check: ${env.BUILD_URL}
                """.stripIndent()

                // slackSend(color: 'danger', message: message, channel: '#builds')
            }
        }
        unstable {
            echo '⚠️ Pipeline is unstable!'
        }
    }
}
